#=-- git-release-updater configuration
#=-- Copy this file to .env and adjust values.
#=-- CLI flags override these values.

# GitHub repository to check for releases
REPO_URL=https://github.com/microsoft/winget-create

# Executable name in the release assets
TARGET_EXE=wingetcreate.exe

# Release version: "latest" or a specific tag like "v1.10.3.0"
VERSION=latest

# Check mode: hash, version, or both
MODE=both

# Path to the local executable to inspect.
# If this is a directory, the target exe name is appended.
EXE_PATH=C:\ProgramData\ITGH\git-release-updater

# Where to save the downloaded file (dir or full path).
# Falls back to EXE_PATH if not set.
OUTPUT_PATH=C:\ProgramData\ITGH\git-release-updater

# Expected SHA-256 hash for download integrity verification.
# Falls back to GitHub asset digest if not set.
# Only needed if GitHub asset lacks a digest field.
# EXPECTED_HASH=sha256:9f56bb326b852a699296e936c7b40dadfaf3ccff01c8e84ecff89871ecff8e5c
